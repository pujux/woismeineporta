# SQLite database file (mounted volume in production: /data/app.db)
DATABASE_PATH=./data/app.db

# Set to 1 to start the in-process availability poller (production: 1)
ENABLE_POLLER=0
# Poll intervals in milliseconds
POLL_FAST_MS=30000
POLL_SLOW_MS=180000

# Optional: route ONLY MediaMarkt fetches through a proxy (its Cloudflare blocks
# datacenter IPs). e.g. the WARP sidecar in docker-compose.warp.yml (GOST on :1080).
# Leave empty = direct. See README → "MediaMarkt hinter Cloudflare WARP".
# MEDIAMARKT_PROXY_URL=socks5://warp:1080

# Bearer token for POST /api/admin/check (manual poll trigger)
ADMIN_SECRET=change-me

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: contact for push services
VAPID_SUBJECT=mailto:you@example.com

# Brevo (email alerts, EU) — https://brevo.com — API key: Account → SMTP & API
BREVO_API_KEY=
# Absender — muss eine in Brevo authentifizierte (Sub-)Domain sein
EMAIL_FROM="Wo is meine Porta? <noreply@woismeineporta.pufler.dev>"
# Optional: Reply-To (z. B. dein PrivateEmail-Postfach), sonst kein Reply-To
EMAIL_REPLY_TO=

# Public base URL — Canonical/OpenGraph, sitemap.xml/robots.txt, E-Mail-Links
PUBLIC_BASE_URL=http://localhost:3000
